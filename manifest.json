{
  "manifest_version": 3,
  "name": "TabHub",
  "version": "0.1.1",
  "description": "把浏览器里散落的标签摊在桌面上，按域名/活跃度/时间聚类。",
  "permissions": ["tabs", "favicon"],
  "action": {
    "default_title": "打开 TabHub",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
